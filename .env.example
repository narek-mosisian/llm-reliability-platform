APP_ENV=local
APP_NAME=llm-reliability-platform
APP_DEBUG=true
LOG_LEVEL=INFO
APP_PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=llm_reliability
POSTGRES_USER=llm_reliability
POSTGRES_PASSWORD=llm_reliability
DATABASE_URL=postgresql+asyncpg://llm_reliability:llm_reliability@postgres:5432/llm_reliability
# Used by SQLAlchemy/asyncpg so that the API knows how to connect to PostgreSQL.

REDIS_URL=redis://redis:6379/0

# LLM API Keys:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

PRIMARY_LLM_PROVIDER=mock
FALLBACK_LLM_PROVIDER=mock
DEFAULT_CHAT_MODEL=gpt-4.1-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI embedding model

DEMO_DAILY_REQUEST_LIMIT=100
DEMO_USER_REQUEST_LIMIT_PER_HOUR=20
MAX_UPLOAD_SIZE_MB=10
MAX_DOCUMENT_CHARS=500000

OTEL_SERVICE_NAME=llm-reliability-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
# Leverages the latest experimental OpenTelemetry conventions for GenAI/LLM telemetry.

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-reliability-platform

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

ENABLE_HYBRID_SEARCH=false
OPENSEARCH_URL=http://opensearch:9200
ELASTICSEARCH_URL=http://elasticsearch:9200
SEARCH_INDEX_NAME=llm_reliability_chunks

ENABLE_LOKI_LOGGING=false
LOKI_URL=http://loki:3100

ENABLE_SEMANTIC_WEB=false
RDF_STORE_PATH=./data/rdf
SPARQL_ENDPOINT=
KG_RAG_MODE=disabled
